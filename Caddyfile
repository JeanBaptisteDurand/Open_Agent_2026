# LPLens internal Caddy — runs inside the project's docker-compose.
# Sits behind the global VPS Caddy (which terminates TLS for lplens.xyz).
# This file routes by path within the LPLens stack:
#   /api/*   → backend (lplens-server :3001)
#   /health  → backend  (so the global Caddy can probe directly too)
#   /        → frontend (lplens-web :80, nginx serving the Vite build)
#
# The global Caddy on the VPS reverse-proxies lplens.xyz → this internal
# Caddy on whatever port docker-compose exposes it (default 8480).

:80 {
  encode gzip

  handle /api/* {
    reverse_proxy lplens-server:3001 {
      header_up Host {host}
      header_up X-Real-IP {remote}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
      flush_interval -1
    }
  }

  handle /health {
    reverse_proxy lplens-server:3001 {
      header_up Host {host}
      header_up X-Real-IP {remote}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
    }
  }

  handle {
    reverse_proxy lplens-web:80 {
      header_up Host {host}
      header_up X-Real-IP {remote}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
    }
  }
}
