# === Deployed LPLens contracts (filled after deploy) ===
LPLENS_REPORTS_CONTRACT=
LPLENS_AGENT_CONTRACT=
# After minting LPLensAgent (one-time), set this to the agent's tokenId.
# Phase 9 will then call updateMemoryRoot + recordDiagnose per run, so
# the iNFT carries verifiable evolving memory + reputation.
LPLENS_AGENT_TOKEN_ID=0
LPLENS_TEE_VERIFIER_CONTRACT=

# === Server ===
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# === Frontend ===
VITE_API_URL=http://localhost:3001
# Used by usePermit2Migration.ts (POST /api/migrate/:tokenId/recorded).
VITE_LPLENS_API_URL=http://localhost:3001
# /agent and /developers pages read these to render live iNFT state and
# the right contract address in the cast call snippets. Mirror the
# server values so the frontend stays in sync after a redeploy.
VITE_LPLENS_AGENT_CONTRACT=
VITE_LPLENS_AGENT_TOKEN_ID=1
VITE_OG_NEWTON_RPC=https://evmrpc-testnet.0g.ai
VITE_OG_CHAIN_ID=16602
# /developers page renders this in the footer + Claude Desktop config
# example. Leave default until the MCP server has a public hostname.
VITE_LPLENS_MCP_URL=mcp.lplens.xyz
