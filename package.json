{
  "name": "lplens",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:server": "pnpm --filter @lplens/server run dev",
    "dev:web": "pnpm --filter @lplens/web run dev",
    "dev:mcp": "pnpm --filter @lplens/mcp-server run dev",
    "build": "pnpm -r run build",
    "db:generate": "pnpm --filter @lplens/server exec prisma generate",
    "db:push": "pnpm --filter @lplens/server exec prisma db push",
    "db:migrate": "pnpm --filter @lplens/server exec prisma migrate dev",
    "db:studio": "pnpm --filter @lplens/server exec prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "test": "pnpm -r run test",
    "test:server": "pnpm --filter @lplens/server run test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
